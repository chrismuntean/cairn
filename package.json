{
  "name": "cairn-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Cairn — state + context-loading layer for AI coding agents (root monorepo).",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "smokes": "pnpm --filter @isaacriehm/cairn smokes",
    "smokes:all": "pnpm --filter @isaacriehm/cairn smokes:all",
    "smoke:llm-prompt-eval": "pnpm --filter @isaacriehm/cairn smoke:llm-prompt-eval",
    "smoke:llm-detect-components": "pnpm --filter @isaacriehm/cairn smoke:llm-detect-components",
    "knip": "knip",
    "knip:strict": "knip --no-progress --max-issues 0",
    "version:check": "node scripts/sync-version.mjs --check",
    "version:sync": "node scripts/sync-version.mjs",
    "release:patch": "node scripts/sync-version.mjs --bump patch",
    "release:minor": "node scripts/sync-version.mjs --bump minor",
    "release:major": "node scripts/sync-version.mjs --bump major",
    "release:set": "node scripts/sync-version.mjs --set",
    "mine": "node tools/mine/mine.mjs",
    "mine:ls": "node tools/mine/mine.mjs ls",
    "mine:session": "node tools/mine/mine.mjs session",
    "mine:histogram": "node tools/mine/mine.mjs histogram",
    "mine:errors": "node tools/mine/mine.mjs errors",
    "mine:cairn": "node tools/mine/mine.mjs cairn"
  },
  "devDependencies": {
    "knip": "^6.16.1",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "tmp": ">=0.2.6",
      "hono": ">=4.12.21",
      "qs": ">=6.15.2",
      "ip-address": ">=10.1.1",
      "brace-expansion@5": ">=5.0.6"
    }
  }
}
