{
  "name": "@devplusllc/harness-core",
  "version": "0.0.0",
  "description": "Harness state + context-loading layer. Curated `.harness/ground/` (decisions, §V invariants, canonical-map, quality-grades), MCP server, init mapper, GC drift sweep, decision-capture extractor, stub catalog, decision-assertion evaluator, spec tightener.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.1",
    "cli-progress": "^3.12.0",
    "ora": "^9.0.0",
    "pino": "^9.5.0",
    "simple-git": "^3.36.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.2"
  },
  "optionalDependencies": {
    "smart-whisper": "^0.8.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
