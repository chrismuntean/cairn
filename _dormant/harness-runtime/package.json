{
  "name": "@devplusllc/harness-runtime",
  "version": "0.0.0",
  "description": "Harness orchestration runtime. FIFO queue, mirror checkout (clone/sync/push), claude subprocess dispatcher, sensor sweep, reviewer subagent, UAT pipeline, watchdog, slash command handlers (/halt /status /queue /eval /resume /oops /archive /unpause). Consumes harness-core for state + context.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@devplusllc/harness-core": "workspace:*",
    "chokidar": "^4.0.1",
    "pino": "^9.5.0",
    "simple-git": "^3.36.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "better-sqlite3": "^11.10.0",
    "playwright-core": "^1.50.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
